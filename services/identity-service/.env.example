# Copy to .env and fill in real values. Never commit the real .env file.

NODE_ENV=development
PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=pulseflow
DB_PASSWORD=changeme_local_dev_only
DB_NAME=pulseflow_identity

# TypeORM synchronize: true is for local dev only. Use real migrations
# before this touches a shared or production database.
DB_SYNCHRONIZE=true

JWT_ACCESS_SECRET=replace_with_long_random_string_local_dev_only
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d
